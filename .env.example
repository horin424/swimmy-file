# Swimmy File — environment variables
#
# Copy this file to `.env.local` (gitignored) and fill in real values there.
# Never commit `.env.local` or any file containing real secrets.

# --- Database -----------------------------------------------------------
# Postgres connection string used by Prisma (src/lib/db.ts, prisma/schema.prisma).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=

# --- AWS: S3 storage + CloudFront delivery -------------------------------
# Region your S3 buckets live in. Used by src/lib/s3.ts when constructing the S3 client.
AWS_REGION=ap-northeast-1

# IAM credentials for the app's S3 access (presigned upload URLs, thumbnail reads/writes).
# Use a scoped IAM user — never the AWS root account. Used by src/lib/s3.ts.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Bucket that stores uploaded video files. Referenced when generating presigned
# PUT URLs in POST /api/uploads/presigned-url and when building playback/storage keys.
AWS_S3_VIDEO_BUCKET=

# Bucket that stores generated video thumbnails. Referenced by the thumbnail
# generation flow and by video detail/list API responses when building thumbnail URLs.
AWS_S3_THUMBNAIL_BUCKET=

# CloudFront distribution domain (e.g. d1234abcd.cloudfront.net) used to build the
# public playback/thumbnail URLs returned to the frontend, instead of raw S3 URLs.
AWS_CLOUDFRONT_DOMAIN=

# --- Auth / tokens --------------------------------------------------------
# Secret used to sign short-lived tokens (email verification links, password
# reset links) in src/lib/auth.ts. NOT used for session auth — sessions are
# DB-backed (Session table + httpOnly cookie), not JWTs, per the agreed auth design.
JWT_SECRET=

# Base URL of the app itself, used server-side to build absolute links (e.g. the
# verification link embedded in emails). Same value as NEXT_PUBLIC_APP_URL below
# in dev; kept separate so server code never depends on a NEXT_PUBLIC_* var.
APP_URL=http://localhost:3000

# --- Outbound email (verification / notifications) ------------------------
# "From" address used when sending verification and notification emails.
EMAIL_FROM=

# SMTP connection details used by the mailer (e.g. src/lib/mail.ts) to send
# verification emails, password reset emails, and admin notifications.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# --- Public (client-side, bundled into the browser build) -----------------
# Anything prefixed NEXT_PUBLIC_ is exposed to browser JS — never put secrets here.
# Displayed in page titles, headers, and metadata (see src/app/layout.tsx, src/components/logo.tsx).
NEXT_PUBLIC_APP_NAME=Swimmy File

# Used client-side to build shareable/absolute links (e.g. the copy-link button
# on the video detail page). Must match APP_URL in any given environment.
NEXT_PUBLIC_APP_URL=http://localhost:3000
