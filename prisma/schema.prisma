// Prisma schema for Swimmy File.
// Note: this project is on Prisma 7, which changed two conventions vs older
// versions/training data: (1) the datasource `url` now lives in prisma.config.ts,
// not in this file, and (2) the client generates to a custom folder (see `output`
// below) instead of node_modules/@prisma/client. Import from "@/generated/prisma/client".

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ------------------------------------------------------------

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
  SUSPENDED
}

enum Visibility {
  PUBLIC
  PRIVATE
  // Quick Share default (see upload-eligibility.ts / use-upload-flow.ts on
  // the frontend): reachable only via its share link, not shown to the
  // uploader's own account as a manageable "private" file the way PRIVATE
  // is. Distinct from PRIVATE so a future "make this private instead of
  // link-only" account-management action isn't ambiguous with the
  // system-assigned Quick Share default.
  LINK_ONLY
}

// Package-level lifecycle (the share link as a whole), distinct from
// PackageFileStatus below (the individual file's own upload/processing state).
enum PackageStatus {
  UPLOADING
  PROCESSING
  ACTIVE
  HIDDEN
  DELETED
  FAILED
}

enum PackageFileStatus {
  UPLOADING
  PROCESSING
  ACTIVE
  FAILED
}

// Client-side detectFileType() in src/lib/file-type.ts mirrors this exactly —
// swapping the mock for real upload responses only touches where the value
// comes from, not the enum shape.
enum FileType {
  VIDEO
  IMAGE
  AUDIO
  DOCUMENT
  ARCHIVE
  OTHER
}

enum ReportReason {
  COPYRIGHT
  SPAM
  ADULT
  VIOLENCE
  OTHER
}

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  REJECTED
}

enum BlacklistType {
  IP
  EMAIL
  USER
}

enum TrustLevel {
  NEW
  TRUSTED
  VETERAN
}

enum InquiryCategory {
  GENERAL
  BUG
  RIGHTS_HOLDER
  DELETE_REQUEST
  OTHER
}

enum InquiryStatus {
  OPEN
  REVIEWING
  CLOSED
}

enum UploaderType {
  GUEST
  USER
}

// Not wired into any billing logic yet (MVP has no payment) — exists so
// paid capacity can be added later without a breaking schema change.
enum StorageEntitlementSource {
  MANUAL
  STRIPE
}

// --- Models -------------------------------------------------------------

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  emailVerified Boolean   @default(false)
  role         Role       @default(USER)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  sharePackages SharePackage[]
  reports     Report[]     @relation("ReportedBy")
  inquiries   Inquiry[]
  adminLogs   AdminLog[]   @relation("AdminActor")
  uploadLimit UploadLimit?
  // Not wired into any billing logic yet — see StorageEntitlement below.
  storageEntitlements StorageEntitlement[]

  @@index([status])
  @@map("users")
}

// A share link now points at a *package* of one or more files (Gofile/
// GigaFile-style multi-file share, not a single-video page — see the
// client's "1 upload session -> multiple files -> 1 shared URL" direction).
// Replaces the old single-file Video model; PackageFile below holds the
// individual files.
model SharePackage {
  id           String       @id @default(cuid())
  ownerType    UploaderType @default(USER)
  // Nullable to support guest uploads (MVP policy: guests can upload up to
  // 1GB cumulative *total across all files in a package* per IP before
  // being required to log in — see GuestUploadUsage below). Always set for
  // ownerType = USER, always null for ownerType = GUEST.
  userId       String?
  // hash(ip + IP_HASH_SALT) of the uploading request's IP, only set for
  // guest uploads — ties this row to the same GuestUploadUsage bucket that
  // enforces the cumulative cap. Never store the raw IP (see
  // GuestUploadUsage's own note and .env.example's IP_HASH_SALT).
  ipHash       String?
  // Quick Share (the default upload mode — see
  // use-multi-file-upload-flow.ts on the frontend) sets this to a name
  // derived from the files themselves at creation time (the single file's
  // own name, or "N files"); there's no DB-level default since that
  // derivation needs the file list. Only changes when Publish to Discover
  // ("Add details for Discover") sets a real title.
  title       String
  description String?
  // LINK_ONLY, not PUBLIC: Quick Share (the default for every upload,
  // guest or logged-in) never makes a package public on its own — only
  // Publish to Discover does, by explicitly setting this to PUBLIC.
  visibility      Visibility    @default(LINK_ONLY)
  status          PackageStatus @default(UPLOADING)
  shareToken      String        @unique
  viewCount       Int           @default(0)
  downloadCount   Int           @default(0)
  reportCount     Int           @default(0)
  // Packages are intentionally excluded from Discover until explicitly
  // enabled (anti-spam gate from the design doc), regardless of
  // status/visibility.
  discoverEnabled Boolean       @default(false)
  // Denormalized sum/count over `files` (BigInt: same reasoning as the old
  // Video.fileSize — a package's total can exceed Int32 range) — kept on
  // the package row so list views (Discover, My Videos) don't need to
  // aggregate PackageFile on every read.
  totalSizeBytes  BigInt        @default(0)
  fileCount       Int           @default(0)
  expiresAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Not in the originally requested field list, but Category otherwise has no
  // relation to SharePackage anywhere in the schema, which would make it a
  // dead table — added as nullable so a package can be uncategorized. Flag
  // if this should be required instead, or removed if Category is meant to
  // stay unlinked for now.
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // SetNull rather than Restrict: now that guest uploads exist (userId
  // already nullable for them), a user closing their account shouldn't be
  // blocked by packages they shared — those links just stop being "owned"
  // by anyone, same as a guest upload always was.
  uploader  User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  files     PackageFile[]
  tags      PackageTag[]
  reports   Report[]
  inquiries Inquiry[]

  @@index([status])
  @@index([visibility])
  @@index([createdAt])
  @@index([viewCount])
  @@index([reportCount])
  @@index([discoverEnabled])
  @@index([ipHash])
  // Composite index matching the actual Discover feed query pattern
  // (WHERE visibility = PUBLIC AND status = ACTIVE AND discoverEnabled = true
  // ORDER BY createdAt DESC) — the single-column indexes above satisfy the
  // literal request; this one is an added recommendation for that specific query.
  @@index([visibility, status, discoverEnabled, createdAt])
  @@map("share_packages")
}

// One row per file inside a SharePackage. A single-file Quick Share still
// gets exactly one of these — there's no special-cased "package of one".
model PackageFile {
  id               String             @id @default(cuid())
  packageId        String
  originalFileName String
  // Editable independently of originalFileName (e.g. a future rename
  // action) — originalFileName never changes after upload, displayName can.
  displayName      String
  // Bytes. Int32 tops out around 2.1GB, well under the product's 50GB max
  // file size, so this must be BigInt rather than Int.
  fileSizeBytes    BigInt
  mimeType         String
  fileType         FileType
  storageKey       String
  thumbnailKey     String?
  // Seconds. Nullable — only meaningful for VIDEO/AUDIO, and unknown until
  // post-upload processing determines it.
  durationSeconds  Int?
  downloadCount    Int                @default(0)
  status           PackageFileStatus  @default(UPLOADING)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  package SharePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
  @@map("package_files")
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  packages SharePackage[]

  @@map("categories")
}

model Tag {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  packages PackageTag[]

  @@map("tags")
}

model PackageTag {
  packageId String
  tagId     String

  package SharePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  tag     Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([packageId, tagId])
  @@index([tagId])
  @@map("package_tags")
}

model Report {
  id         String       @id @default(cuid())
  packageId  String
  reporterId String?
  reason     ReportReason
  message    String?
  status     ReportStatus @default(OPEN)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  package  SharePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  reporter User?        @relation("ReportedBy", fields: [reporterId], references: [id], onDelete: SetNull)

  @@index([packageId])
  @@index([status])
  @@map("reports")
}

model Blacklist {
  id        String        @id @default(cuid())
  type      BlacklistType
  value     String
  reason    String?
  createdAt DateTime      @default(now())

  @@unique([type, value])
  @@map("blacklist")
}

model UploadLimit {
  id           String     @id @default(cuid())
  userId       String     @unique
  dailyCount   Int        @default(0)
  // Bytes. 10GB (the default total-storage cap) exceeds Int32 range, same
  // reasoning as PackageFile.fileSizeBytes — must be BigInt.
  storageUsed  BigInt     @default(0)
  // Explicit stored cap rather than a value derived purely from trustLevel
  // in app code — lets a future paid plan (see Plan/StorageEntitlement
  // below) raise this per-user without changing the trust-level ladder.
  // Nullable so existing rows can fall back to the trust-level default
  // until backfilled.
  storageLimitBytes BigInt?
  trustLevel   TrustLevel @default(NEW)
  lastResetAt  DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("upload_limits")
}

// Guest (not-logged-in) upload policy: up to 1GB cumulative per IP before
// requiring login/signup (see GET /api/upload/eligibility in
// src/lib/upload-eligibility.ts for the frontend contract this backs).
// One row per hashed IP — never the raw address.
model GuestUploadUsage {
  id     String @id @default(cuid())
  // hash(ip + IP_HASH_SALT). IP_HASH_SALT is an env var (see .env.example)
  // so the hash isn't reversible without it, and can be rotated.
  ipHash String @unique

  // Bytes. Same BigInt reasoning as PackageFile.fileSizeBytes/UploadLimit.storageUsed.
  totalUploadedBytes BigInt   @default(0)
  lastUploadedAt     DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("guest_upload_usage")
}

// --- Future billing extension (not implemented, not referenced by any
// logic yet) ---------------------------------------------------------------
// Kept here so adding paid capacity later is additive (new rows/relations)
// rather than a schema migration that touches SharePackage/User/UploadLimit.

model Plan {
  id                String @id @default(cuid())
  name              String
  storageLimitBytes BigInt
  maxFileSizeBytes  BigInt
  // Integer minor units (cents), not a float — avoids floating-point
  // rounding errors on money. $9.99 = 999.
  priceCents        Int
  createdAt         DateTime @default(now())

  @@map("plans")
}

model StorageEntitlement {
  id                     String                    @id @default(cuid())
  userId                 String
  additionalStorageBytes BigInt
  source                 StorageEntitlementSource
  // Null = doesn't expire (e.g. a one-time manual grant).
  expiresAt              DateTime?
  createdAt              DateTime                  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("storage_entitlements")
}

model AdminLog {
  id           String   @id @default(cuid())
  adminUserId  String
  action       String
  targetType   String
  targetId     String
  metadata     Json?    @db.JsonB
  createdAt    DateTime @default(now())

  // Restrict rather than Cascade/SetNull: audit log integrity should block
  // deleting an admin account that has log entries, not silently lose them.
  adminUser User @relation("AdminActor", fields: [adminUserId], references: [id], onDelete: Restrict)

  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("admin_logs")
}

model Inquiry {
  id               String          @id @default(cuid())
  userId           String?
  email            String
  category         InquiryCategory
  subject          String
  message          String
  relatedPackageId String?
  status           InquiryStatus   @default(OPEN)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  relatedPackage SharePackage? @relation(fields: [relatedPackageId], references: [id], onDelete: SetNull)

  @@index([status])
  @@map("inquiries")
}
